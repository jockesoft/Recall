@page "{id:int}"
@model Recall.Web.Pages.Series.DetailsModel
@using Recall.Web.Pages.Shared
@{
    ViewData["Title"] = Model.Series is null ? "Series Details" : Model.Series.Name;
    var status = Model.Aggregate?.Status;
    var isContinuing = status is { KeepUpdated: true };
}

<a asp-page="/Series/Search" class="tvdb-back-link">&larr; Back to search</a>

<div class="tvdb-shell">
    @if (Model.Series is null || Model.Aggregate is null)
    {
        <div class="alert alert-warning">Series not found.</div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-md-4">
                <div class="tvdb-media @(string.IsNullOrWhiteSpace(Model.Series.ImageUrl) ? "is-empty" : "")">
                    @if (!string.IsNullOrWhiteSpace(Model.Series.ImageUrl))
                    {
                        <img src="@Model.Series.ImageUrl" alt="@Model.Series.Name" />
                    }
                    @if (status?.Name is not null)
                    {
                        <div class="tvdb-slate">
                            <span class="tvdb-dot @(isContinuing ? "is-ok" : "")" aria-hidden="true"></span>
                            <span>@status.Name.ToUpperInvariant()</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-8">
                <h1 class="tvdb-display mb-2">@Model.Series.Name</h1>

                <form method="post" asp-page-handler="ToggleLibrary" asp-route-id="@Model.Series.TvdbId" asp-route-season="@Model.Season" class="mb-3">
                    <button type="submit" class="btn @(Model.IsTrackedByCurrentUser ? "btn-outline-danger" : "btn-primary")">
                        @(Model.IsTrackedByCurrentUser ? "Remove from library" : "Save to library")
                    </button>
                </form>

                <dl class="row">
                    <dt class="col-sm-3">TVDB Id</dt>
                    <dd class="col-sm-9">@Model.Series.TvdbId</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.Series.FirstAired))
                    {
                        <dt class="col-sm-3">First aired</dt>
                        <dd class="col-sm-9">@Model.Series.FirstAired</dd>
                    }

                    @if (Model.Series.Score.HasValue)
                    {
                        <dt class="col-sm-3">Score</dt>
                        <dd class="col-sm-9">@Model.Series.Score.Value.ToString("0.0")</dd>
                    }
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Series.Overview))
                {
                    <h5>Overview</h5>
                    <p class="tvdb-prose">@Model.Series.Overview</p>
                }
            </div>
        </div>
    var cast = Model.Aggregate.Characters
        .Where(c => !string.IsNullOrWhiteSpace(c.PersonName) || !string.IsNullOrWhiteSpace(c.Name))
        .OrderBy(c => c.Sort ?? int.MaxValue)
        .ThenBy(c => c.PersonName ?? c.Name)
        .ToList();


        if (cast.Count > 0)
        {
            <hr class="my-4" />
            <h4 class="mb-3">Cast &amp; Characters</h4>

            <div class="cast-container" id="castContainer">
                <div class="row g-3" id="castGrid">
                    @foreach (var ch in cast)
                    {
                        var personDisplay = string.IsNullOrWhiteSpace(ch.PersonName) ? "Unknown person" : ch.PersonName;
                        var characterDisplay = string.IsNullOrWhiteSpace(ch.Name) ? null : ch.Name;
                        var imageUrl = !string.IsNullOrWhiteSpace(ch.PersonImageUrl) ? ch.PersonImageUrl : ch.Image;
                        var hasLink = !string.IsNullOrWhiteSpace(ch.Url);

                        <div class="col-12 col-sm-6 col-lg-4 cast-item">
                            <div class="h-100 d-flex p-3 gap-3 align-items-start form-control">
                                <div class="flex-shrink-0">
                                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                                    {
                                        <img src="@imageUrl"
                                             alt="@personDisplay"
                                             class="rounded"
                                             style="width:72px;height:72px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded d-flex align-items-center justify-content-center tvdb-slate--inline"
                                             style="width:72px;height:72px;">
                                            No image
                                        </div>
                                    }
                                </div>

                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate" style="color:var(--tvdb-text);">@personDisplay</div>

                                    @if (!string.IsNullOrWhiteSpace(characterDisplay))
                                    {
                                        <div class="small text-truncate tvdb-mono" style="color:var(--tvdb-text-muted);">
                                            as @characterDisplay
                                        </div>
                                    }

                                    <div class="mt-2 d-flex flex-wrap gap-2">
                                        @if (ch.IsFeatured)
                                        {
                                            <span class="tvdb-badge tvdb-badge--ok">Featured</span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(ch.PeopleType))
                                        {
                                            <span class="tvdb-badge tvdb-badge--amber">@ch.PeopleType</span>
                                        }
                                    </div>

                                    @if (hasLink)
                                    {
                                        <div class="mt-2">
                                            <a href="@ch.Url"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="tvdb-mono small"
                                               style="color:var(--tvdb-signal);text-decoration:none;">
                                                View on TheTVDB ↗
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (cast.Count > 6)
                {
                    <div class="cast-expand-container mt-3">
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="castToggleBtn" onclick="toggleCast()">
                            <span class="tvdb-mono">Show @(cast.Count - 6) more</span>
                            <span class="ms-2" id="castToggleIcon">▼</span>
                        </button>
                    </div>
                }
            </div>

            <style>
                #castGrid .cast-item:nth-child(n+7) {
                    display: none;
                }
                
                #castContainer.is-expanded #castGrid .cast-item:nth-child(n+7) {
                    display: block;
                }
                
                #castToggleIcon {
                    display: inline-block;
                    transition: transform 0.3s ease;
                }
                
                #castContainer.is-expanded #castToggleIcon {
                    transform: rotate(180deg);
                }
            </style>

            <script>
                function toggleCast() {
                    const container = document.getElementById('castContainer');
                    const btn = document.getElementById('castToggleBtn');
                    const isExpanded = container.classList.contains('is-expanded');
                    
                    if (isExpanded) {
                        container.classList.remove('is-expanded');
                        btn.innerHTML = '<span class="tvdb-mono">Show @(cast.Count - 6) more</span><span class="ms-2" id="castToggleIcon">▼</span>';
                    } else {
                        container.classList.add('is-expanded');
                        btn.innerHTML = '<span class="tvdb-mono">Show less</span><span class="ms-2" id="castToggleIcon">▼</span>';
                    }
                }
            </script>
        }
        
        var seasonNumbers = Model.Aggregate.Seasons
            .Select(s => s.Number)
            .Where(n => n.HasValue)
            .Select(n => n!.Value)
            .Distinct()
            .OrderBy(n => n)
            .ToList();

        var selectedSeason = Model.Season ?? seasonNumbers.FirstOrDefault();

        var filteredEpisodes = Model.Aggregate.Episodes
            .Where(e => e.SeasonNumber == selectedSeason)
            .OrderBy(e => e.EpisodeNumber ?? int.MaxValue)
            .ThenBy(e => e.Id)
            .ToList();

        if (seasonNumbers.Count > 0)
        {
            <hr class="my-4"/>

            <h4 class="mb-3">Seasons</h4>
            <div class="d-flex flex-wrap gap-2 mb-4">
                @foreach (var seasonNumber in seasonNumbers)
                {
                    var isActive = seasonNumber == selectedSeason;
                    <a asp-page="/Series/Details"
                       asp-route-id="@Model.Series.TvdbId"
                       asp-route-season="@seasonNumber"
                       class="btn @(isActive ? "btn-dark" : "btn-outline-dark") btn-sm rounded-pill px-3">
                        @Model.GetSeasonName(seasonNumber)
                    </a>
                }
            </div>

            <h5 class="mb-3 tvdb-eyebrow">Episodes &middot; @Model.GetSeasonName(selectedSeason)</h5>

            @if (filteredEpisodes.Count == 0)
            {
                <div class="alert alert-info">No episodes found for this season.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var ep in filteredEpisodes)
                    {
                        var isWatched = Model.WatchedEpisodeIds.Contains(ep.Id);
                        <div class="list-group-item @(isWatched ? "is-watched" : "")">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">
                                        <span class="tvdb-mono">E@(ep.EpisodeNumber?.ToString() ?? "?")</span>
                                        &mdash; <a asp-page="/Episodes/Details" asp-route-id="@ep.Id">@ep.Name</a>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(ep.Overview))
                                    {
                                        <div class="text-muted small mt-1">@ep.Overview</div>
                                    }
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-end small tvdb-mono text-muted">
                                        @if (ep.Aired.HasValue)
                                        {
                                            <div>@ep.Aired.Value.ToString("yyyy-MM-dd")</div>
                                        }
                                        @if (ep.RuntimeMinutes.HasValue)
                                        {
                                            <div>@ep.RuntimeMinutes min</div>
                                        }
                                    </div>

                                    <partial name="_EpisodeWatchedToggle" model="@(new EpisodeWatchedToggleModel
                                             {
                                                 Handler = "ToggleEpisodeWatched",
                                                 RouteId = Model.Series.TvdbId,
                                                 IsWatched = isWatched,
                                                 Compact = true,
                                                 HiddenFields = new Dictionary<string, string>
                                                 {
                                                     ["episodeId"] = ep.Id.ToString(),
                                                     ["Season"] = selectedSeason.ToString()
                                                 }
                                             })" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</div>
