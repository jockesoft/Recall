@page
@model Recall.Web.Pages.Series.LibraryModel
@{
    ViewData["Title"] = "My Library";
}

<h1 class="mb-3">My Library</h1>

<div class="mb-3">
    <a asp-page="/Series/Search" class="btn btn-outline-primary">Find series</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}
else if (Model.Items.Count == 0)
{
    <div class="alert alert-info" role="alert">
        Your library is empty. Search and save series to get started.
    </div>
}
else
{
    <p class="text-muted">You have @Model.Items.Count tracked series.</p>

    <div class="list-group">
        @foreach (var item in Model.Items)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div class="flex-grow-1">
                        <h5 class="mb-1">@item.Name</h5>

                        <div class="small text-muted mb-2">
                            TVDB: @item.TvdbId
                            @if (item.FirstAired.HasValue)
                            {
                                <span> • First aired: @item.FirstAired.Value.ToString("yyyy-MM-dd")</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.Overview))
                        {
                            <p class="mb-0 text-muted">@item.Overview</p>
                        }
                    </div>

                    <div class="d-flex flex-column gap-2">
                        <a asp-page="/Series/Details"
                           asp-route-id="@item.TvdbId"
                           class="btn btn-sm btn-outline-secondary">
                            View
                        </a>

                        <form method="post" asp-page-handler="Remove" asp-route-id="@item.Id">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Remove
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}