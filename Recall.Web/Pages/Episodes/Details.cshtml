@page "{id:int}"
@model Recall.Web.Pages.Episodes.DetailsModel
@using Recall.Web.Domain.TheTvDb
@using Recall.Web.Pages.Shared

@{
    var ep = Model.Episode;
    ViewData["Title"] = ep?.Name ?? "Episode";

    string? FormatAired(string? aired)
    {
        if (string.IsNullOrWhiteSpace(aired)) return null;
        return DateOnly.TryParse(aired, out var d) ? d.ToString("MMMM d, yyyy") : aired;
    }

    string? FormatRuntime(int? minutes)
    {
        if (minutes is null or <= 0) return null;
        var h = minutes.Value / 60;
        var m = minutes.Value % 60;
        return h > 0 ? $"{h}h {m:D2}m" : $"{minutes} min";
    }

    string SlateCode(Episode e)
    {
        if (e.IsMovie) return "MOVIE";
        var s = e.SeasonNumber?.ToString("D2") ?? "--";
        var n = e.Number?.ToString("D2") ?? "--";
        return $"S{s} \u00B7 E{n}";
    }

    string? FinaleLabel(string? finaleType) => finaleType?.ToLowerInvariant() switch
    {
        "series" => "Series finale",
        "season" => "Season finale",
        "midseason" => "Midseason finale",
        _ => null
    };

    var airedText = ep is null ? null : FormatAired(ep.Aired);
    var runtimeText = ep is null ? null : FormatRuntime(ep.Runtime);
    var finaleText = ep is null ? null : FinaleLabel(ep.FinaleType);
    var eyebrowParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(ep?.SeasonName)) eyebrowParts.Add(ep.SeasonName!.ToUpperInvariant());
    if (!string.IsNullOrWhiteSpace(ep?.Year)) eyebrowParts.Add(ep.Year!);
    if (ep?.AbsoluteNumber is not null) eyebrowParts.Add($"ABS #{ep.AbsoluteNumber}");
}

@if (ep?.SeriesId is not null)
{
    <a class="tvdb-back-link" href="/Series/Details/@ep.SeriesId">&larr; Back to series</a>
}

<div class="tvdb-shell">
    @if (ep is null)
    {
        <p class="tvdb-prose">This episode could not be loaded.</p>
    }
    else
    {
        <div class="row g-4">
            <div class="col-md-5">
                <div class="tvdb-media is-wide @(string.IsNullOrWhiteSpace(ep.Image) ? "is-empty" : "")">
                    @if (!string.IsNullOrWhiteSpace(ep.Image))
                    {
                        <img src="@ep.Image" alt="Still from @ep.Name" loading="lazy" />
                    }
                    <div class="tvdb-slate">
                        <span class="tvdb-dot" aria-hidden="true"></span>
                        <span>@SlateCode(ep)</span>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                @if (eyebrowParts.Count > 0)
                {
                    <div class="tvdb-eyebrow mb-1">@string.Join(" \u00B7 ", eyebrowParts)</div>
                }

                <h1 class="tvdb-display mb-2">@(ep.Name ?? "Untitled episode")</h1>

                <div class="d-flex flex-wrap gap-3 tvdb-mono text-muted mb-3 pb-2" style="border-bottom: 1px solid var(--tvdb-ink-line);">
                    @if (airedText is not null)
                    {
                        <span>Aired &nbsp;@airedText</span>
                    }
                    @if (runtimeText is not null)
                    {
                        <span>Runtime &nbsp;@runtimeText</span>
                    }
                </div>

                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    @if (finaleText is not null)
                    {
                        <span class="tvdb-badge tvdb-badge--amber d-inline-block">@finaleText</span>
                    }

                    @if (Model.IsWatchedByCurrentUser)
                    {
                        <partial name="_EpisodeWatchedToggle" model="@(new EpisodeWatchedToggleModel
                                 {
                                     Handler = "ToggleWatched",
                                     RouteId = ep.Id!.Value,
                                     IsWatched = true
                                 })" />
                    }
                    else if (Model.PriorUnwatchedCount == 0)
                    {
                        <partial name="_EpisodeWatchedToggle" model="@(new EpisodeWatchedToggleModel
                                 {
                                     Handler = "ToggleWatched",
                                     RouteId = ep.Id!.Value,
                                     IsWatched = false
                                 })" />
                    }
                    else
                    {
                        <button type="button" class="btn btn-watch" data-bs-toggle="modal" data-bs-target="#markWatchedModal">
                            Mark as watched
                        </button>

                        <div class="modal fade" id="markWatchedModal" tabindex="-1" aria-labelledby="markWatchedModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="markWatchedModalLabel">Catch up?</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body tvdb-prose">
                                        You have <strong>@Model.PriorUnwatchedCount</strong> earlier unwatched episode@(Model.PriorUnwatchedCount == 1 ? "" : "s") in this series.
                                        Mark @(Model.PriorUnwatchedCount == 1 ? "it" : "those") as watched too?
                                    </div>
                                    <div class="modal-footer">
                                        <form method="post" asp-page-handler="ToggleWatched" asp-route-id="@ep.Id">
                                            <button type="submit" class="btn btn-outline-dark">Just this episode</button>
                                        </form>
                                        <form method="post" asp-page-handler="MarkWatchedThrough" asp-route-id="@ep.Id">
                                            <button type="submit" class="btn btn-watch">Mark this &amp; earlier episodes</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(ep.Overview))
                {
                    <p class="tvdb-prose">@ep.Overview</p>
                }
                else
                {
                    <p class="tvdb-prose text-muted fst-italic">No overview available for this episode yet.</p>
                }

                <div class="tvdb-mono text-muted small mt-4 pt-2" style="border-top: 1px solid var(--tvdb-ink-line);">
                    Episode ID @ep.Id
                    @if (ep.LastUpdated is not null)
                    {
                        <span class="ms-3">Updated @ep.LastUpdated</span>
                    }
                </div>
            </div>
        </div>
    }
</div>
